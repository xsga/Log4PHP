{
  "name": "xsga/log4php",
  "description": "A PHP logging library based on Apache Log4PHP, PSR-3 compliant, supporting multiple appenders, layouts and log levels.",
  "type": "library",
  "license": "Apache-2.0",
  "homepage": "https://github.com/xsga/Log4PHP",
  "keywords": ["log", "logging", "log4php", "psr-3", "logger"],
  "authors": [
    {
      "name": "Parker",
      "email": "parker@xsga.es"
    }
  ],
  "require": {
    "php": "^8.4",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "^4.0",
    "vimeo/psalm": "^6.14",
    "php-parallel-lint/php-parallel-lint": "^1.4",
    "php-parallel-lint/php-console-highlighter": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Xsga\\Log4Php\\": "src/Xsga/Log4Php/"
    }
  },
  "scripts": {
    "lint": "parallel-lint --exclude vendor .",
    "style": "phpcs -p --colors --standard=PSR12 src",
    "style-fix": "phpcbf -p --standard=PSR12 src",
    "analyze-errors": "psalm --output-format=console --show-info=false --no-cache",
    "analyze-info": "psalm --output-format=console --show-info=true --no-cache"
  }
}
